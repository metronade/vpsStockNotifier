# Copy to .env and adjust as needed

# SQLite database path (inside backend container)
DB_PATH=/app/data/app.db

# Log directory (inside backend container)
LOG_DIR=/app/logs

# Playwright
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_DEFAULT_TIMEOUT_MS=15000

# Default scan interval for new providers (seconds)
DEFAULT_SCAN_INTERVAL_SECONDS=300

# Optional: seed Telegram credentials.
# Leave empty to configure via the dashboard instead.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
